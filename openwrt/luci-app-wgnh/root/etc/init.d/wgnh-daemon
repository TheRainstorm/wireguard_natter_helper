#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

load_admin_token() {
	local token_file="$1"
	if [ -z "$WGNH_ADMIN_TOKEN" ] && [ -r "$token_file" ]; then
		WGNH_ADMIN_TOKEN="$(sed -n '1p' "$token_file")"
	fi
}

start_service() {
	config_load wgnh
	local enabled binary state listen_addr admin_token_file natter_cooldown
	config_get_bool enabled daemon enabled 0
	[ "$enabled" = "1" ] || return 0
	config_get binary daemon binary /usr/bin/wgnh
	config_get state daemon state /etc/wgnh/state.json
	config_get listen_addr daemon listen_addr 0.0.0.0:3333
	config_get WGNH_ADMIN_TOKEN daemon admin_token ''
	config_get admin_token_file daemon admin_token_file /etc/wgnh/admin-token
	config_get natter_cooldown daemon natter_cooldown 5m
	load_admin_token "$admin_token_file"

	procd_open_instance
	procd_set_param command "$binary" daemon serve --state "$state" --addr "$listen_addr" --admin-token "$WGNH_ADMIN_TOKEN" --natter-cooldown "$natter_cooldown"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger wgnh
}
