#!/bin/sh /etc/rc.common

START=92
STOP=10
USE_PROCD=1

start_service() {
	config_load wgnh
	local enabled binary listen_addr daemon_addr
	config_get_bool enabled web enabled 0
	[ "$enabled" = "1" ] || return 0
	config_get binary web binary /usr/bin/wgnh
	config_get listen_addr web listen_addr 0.0.0.0:9090
	config_get daemon_addr web daemon_addr 127.0.0.1:3333

	procd_open_instance
	procd_set_param command "$binary" web --addr "$listen_addr" --daemon-addr "$daemon_addr"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger wgnh
}
