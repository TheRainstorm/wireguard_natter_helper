{
  "daemon_addr": "127.0.0.1:3333",
  "join_code": "replace-with-domain-join-code",
  "node_name": "home-a",
  "state_path": "/etc/wgnh/node-state.json",
  "retry_seconds": 5,
  "wireguard": [
    {
      "name": "wg0",
      "listen_port": 51820,
      "config_type": "openwrt_uci"
    }
  ],
  "natter": {
    "stop_wireguard": false,
    "command": [
      "python3",
      "examples/fake-natter.py"
    ],
    "timeout_seconds": 30
  }
}
