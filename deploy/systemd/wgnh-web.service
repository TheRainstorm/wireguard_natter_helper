[Unit]
Description=WireGuard Natter Helper Web UI
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/wgnh/web.env
ExecStart=/usr/local/bin/wgnh web --addr=${WGNH_WEB_ADDR} --daemon-addr=${WGNH_DAEMON_ADDR}
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
