[Unit]
Description=WireGuard Natter Helper agent
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/wgnh/agent.env
ExecStart=/usr/local/bin/wgnh agent --daemon-addr=${WGNH_DAEMON_ADDR}
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
