#!/bin/sh /etc/rc.common

START=92
STOP=10
USE_PROCD=1

WGNH_BIN="${WGNH_BIN:-/usr/bin/wgnh}"
WGNH_WEB_ADDR="${WGNH_WEB_ADDR:-0.0.0.0:9090}"
WGNH_DAEMON_ADDR="${WGNH_DAEMON_ADDR:-127.0.0.1:3333}"

start_service() {
	procd_open_instance
	procd_set_param command "$WGNH_BIN" web --addr "$WGNH_WEB_ADDR" --daemon-addr "$WGNH_DAEMON_ADDR"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}
