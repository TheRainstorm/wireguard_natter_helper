#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

WGNH_BIN="${WGNH_BIN:-/usr/bin/wgnh}"
WGNH_CONFIG="${WGNH_CONFIG:-/etc/wgnh/agent.json}"

start_service() {
	procd_open_instance
	procd_set_param command "$WGNH_BIN" agent --config "$WGNH_CONFIG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}
